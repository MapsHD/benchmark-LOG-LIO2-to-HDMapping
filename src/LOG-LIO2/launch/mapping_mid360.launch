<launch>
    <!-- Launch file for Livox MID-360 (Bunker DVI / reg-1) -->

    <arg name="rviz" default="true"/>
    <arg name="debug" default="false"/>

    <param name="/use_sim_time" value="true"/>
    <rosparam command="load" file="$(find log_lio)/config/mid360.yaml"/>

    <arg name="data_path" default="/ros_ws/dataset" />
    <arg name="bag_file" default="$(arg data_path)/reg-1.bag"/>

    <group if="$(eval arg('debug') == False)">
        <node pkg="log_lio" type="log_lio_node" name="log_lio_node" output="screen">
            <param name="bag_file" type="string" value="$(arg bag_file)"/>
        </node>
    </group>

    <group if="$(arg rviz)">
        <node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz"
              args="-d $(find log_lio)/config/rviz_cfg/voxel_mapping.rviz"/>
    </group>
</launch>
